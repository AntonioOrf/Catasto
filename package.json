{
  "name": "catasto-monorepo",
  "private": true,
  "workspaces": [
    "frontend-catasto",
    "backend-catasto",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w catasto-frontend\" \"npm run dev -w catasto-backend\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18"
  }
}
